              "LogDriver": "awslogs",
              "Options": {
                "awslogs-group": {
                  "Ref": "LogGroupName"
                },
                "awslogs-region": {
                  "Ref": "AWS::Region"
                },
                "awslogs-stream-prefix": "ecs"
              }
            },
            "Name": "cache",
            "PortMappings": [],
            "ReadonlyRootFilesystem": false,
            "ResourceRequirements": []
