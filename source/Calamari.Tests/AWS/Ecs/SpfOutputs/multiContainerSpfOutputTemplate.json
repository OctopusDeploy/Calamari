        "LaunchType": "FARGATE",
        "NetworkConfiguration": {
          "AwsvpcConfiguration": {
            "AssignPublicIp": "ENABLED",
            "SecurityGroups": [
              "sg-0d5e06a4bde84daaa"
            ],
            "Subnets": [
              "subnet-0650cd8a2119e8aaa"
            ]
          }
        },
        "Tags": [
          {
            "Key": "my-tag",
            "Value": "a great test value"
          }
        ],
        "TaskDefinition": {
          "Ref": "TaskDefinitiontestMultiContainerTemplate"
        }
