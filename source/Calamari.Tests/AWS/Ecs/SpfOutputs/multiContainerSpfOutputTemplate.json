          {
            "DisableNetworking": false,
            "DnsSearchDomains": [],
            "DnsServers": [],
            "EnvironmentFiles": [],
            "Essential": true,
            "ExtraHosts": [],
            "HealthCheck": {
              "Command": [
                " [ \"CMD-SHELL\", \"curl -f http://localhost/ || exit 1\" ]."
              ]
            },
            "Image": "docker.io/bitnami/redis:sha256-fd997c4c52c0a0af686e5af2b671f4e3d538d26f28abd3b83a01ce57eea43752.sig",
